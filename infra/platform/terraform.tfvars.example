# Copy to terraform.tfvars and replace placeholder values before apply.

project     = "devops-tracker"
environment = "dev"
location    = "swedencentral"

github_owner  = "Lajahom123"
github_repo   = "devops-basics"
github_branch = "main"

tags = {
  owner = "owner@example.com"
}

owner_email = "owner@example.com"

alert_evaluation_frequency = "PT5M"
alert_window_duration      = "PT15M"

kubernetes_namespace = "devops-tracker"

enable_high_latency_alert = true
high_latency_threshold_ms = 1000

enable_pod_restart_alert = true
pod_restart_threshold    = 0

enable_failed_pod_alert = true

# Object ID of the general admin or service principal added to devops-tracker-postgres-admins.
postgres_admin_member_object_id = "00000000-0000-0000-0000-000000000000"
