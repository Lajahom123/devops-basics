FROM ubuntu:24.04

RUN apt-get update \
  && DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    gnupg \
    lsb-release \
    postgresql-client \
  && curl -sL https://aka.ms/InstallAzureCLIDeb | bash \
  && apt-get clean \
  && rm -rf /var/lib/apt/lists/*

COPY scripts/bootstrap-postgres-entra-principal.sh /opt/postgres-bootstrap/bootstrap-postgres-entra-principal.sh
COPY infra/runtime-aks/sql/bootstrap-postgres-entra-principal.sql /opt/postgres-bootstrap/bootstrap-postgres-entra-principal.sql
COPY infra/runtime-aks/sql/grant-app-permissions.sql /opt/postgres-bootstrap/grant-app-permissions.sql
COPY infra/runtime-aks/sql/grant-migration-permissions.sql /opt/postgres-bootstrap/grant-migration-permissions.sql

RUN chmod +x /opt/postgres-bootstrap/bootstrap-postgres-entra-principal.sh \
  && useradd --create-home --shell /usr/sbin/nologin bootstrap \
  && chown -R bootstrap:bootstrap /opt/postgres-bootstrap

USER bootstrap

WORKDIR /opt/postgres-bootstrap

ENTRYPOINT ["/opt/postgres-bootstrap/bootstrap-postgres-entra-principal.sh"]
